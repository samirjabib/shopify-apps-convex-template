SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
# Comma-separated. Must match `[access_scopes].scopes` in shopify.app.toml.
SCOPES=write_products

# Optional: only set if you use a custom shop domain (e.g. shop.example.com).
# When unset, only `*.myshopify.com` hosts are accepted as valid shops.
# SHOP_CUSTOM_DOMAIN=

# Convex (filled by `npm run convex:dev -- --once` for local backend)
CONVEX_URL=
VITE_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Billing — opt-in. Default `none` ships an unbilled template.
# Set `mantle` and fill the two keys below to enable the Mantle adapter.
# Sign up free (Core plan: $0/mo under $5K MTR): https://heymantle.com
BILLING_PROVIDER=none
# MANTLE_APP_ID=
# MANTLE_API_KEY=
