SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=write_products

# Convex (filled during `npx convex dev` + `npm run convex:key` locally).
CONVEX_URL=
VITE_CONVEX_URL=
# Deployment admin key (Convex dashboard → Settings → Deploy keys → Admin).
# NOT the project deploy key used by `npx convex deploy` — those are distinct.
# On local dev this is auto-populated by `scripts/convex-key.js`.
CONVEX_ADMIN_KEY=
