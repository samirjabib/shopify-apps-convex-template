# Shopify auth — recommended: run `shopify app env pull` to populate these
# automatically once `shopify app config link` has linked your app.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
# `shopify.app.toml` is the source of truth for scopes. This var is read by the
# RR7 runtime; keep it in sync with `[access_scopes].scopes` in the toml or
# leave blank and let `shopify app env pull` fill it.
SCOPES=

# Optional: only set if you use a custom shop domain (e.g. shop.example.com).
# When unset, only `*.myshopify.com` hosts are accepted as valid shops.
# SHOP_CUSTOM_DOMAIN=

# Convex (filled by `npm run convex:dev -- --once` for local backend)
CONVEX_URL=
VITE_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Billing — opt-in.
# `none`   = no billing UI/checks. App runs free for all users (default).
# `mantle` = enable Mantle adapter; fill the two keys below.
# Sign up free (Core plan: $0/mo under $5K MTR): https://heymantle.com
BILLING_PROVIDER=none
# MANTLE_APP_ID=
# MANTLE_API_KEY=
